---
---

<div class="accordion">
  <slot />
</div>

<style>
  .accordion {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
</style>

<script is:inline type="module">
  function handleAccordionToggle(button) {
    if (!(button instanceof HTMLElement)) return;

    const accordion = button.closest(".accordion");
    if (!accordion) return;

    const allItems = accordion.querySelectorAll(".accordion-item");

    allItems.forEach((el) => {
      const itemButton = el.querySelector(".accordion-trigger");
      const isClicked = itemButton === button;

      if (!(itemButton instanceof HTMLElement)) return;

      if (isClicked) {
        el.classList.toggle("open");
        itemButton.setAttribute(
          "aria-expanded",
          String(el.classList.contains("open"))
        );
      } else {
        el.classList.remove("open");
        itemButton.setAttribute("aria-expanded", "false");
      }
    });
  }

  function setupAccordionDelegation() {
    if (window.__afcAccordionBound) return;
    window.__afcAccordionBound = true;

    document.addEventListener("click", (e) => {
      const target = e.target instanceof Element ? e.target : null;
      const button = target?.closest(".accordion-trigger");
      if (!button) return;

      handleAccordionToggle(button);
    });

    document.addEventListener("keydown", (e) => {
      const button = e.target instanceof HTMLElement ? e.target : null;
      if (!button?.classList.contains("accordion-trigger")) return;

      const accordion = button.closest(".accordion");
      if (!accordion) return;

      const allItems = Array.from(
        accordion.querySelectorAll(".accordion-item")
      );
      const currentItem = button.closest(".accordion-item");
      const currentIndex = currentItem ? allItems.indexOf(currentItem) : -1;

      if (currentIndex === -1) return;

      switch (e.key) {
        case "Enter":
        case " ": {
          e.preventDefault();
          handleAccordionToggle(button);
          break;
        }
        case "ArrowDown": {
          e.preventDefault();
          const nextIndex = (currentIndex + 1) % allItems.length;
          const nextButton = allItems[nextIndex]?.querySelector(
            ".accordion-trigger"
          );
          if (nextButton instanceof HTMLElement) {
            nextButton.focus();
          }
          break;
        }
        case "ArrowUp": {
          e.preventDefault();
          const prevIndex =
            (currentIndex - 1 + allItems.length) % allItems.length;
          const prevButton = allItems[prevIndex]?.querySelector(
            ".accordion-trigger"
          );
          if (prevButton instanceof HTMLElement) {
            prevButton.focus();
          }
          break;
        }
      }
    });
  }

  setupAccordionDelegation();

  document.addEventListener("astro:after-swap", setupAccordionDelegation);
</script>
