---
interface Props {
  title: string;
  content?: string;
}

const { title, content } = Astro.props;

const panelId = `accordion-panel-${Math.random().toString(36).slice(2, 11)}`;
const buttonId = `${panelId}-trigger`;

const hasSlotContent = Boolean(Astro.slots.default);
---

<div class="accordion-item">
  <button
    class="accordion-trigger"
    type="button"
    aria-expanded="false"
    aria-controls={panelId}
    id={buttonId}
  >
    <span class="accordion-title">{title}</span>
    <span class="accordion-icon">
      <svg
        class="icon-plus"
        viewBox="0 0 16 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M8 3v10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"></path>
        <path d="M3 8h10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"></path>
      </svg>
      <svg
        class="icon-minus"
        viewBox="0 0 16 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M3 8h10" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"></path>
      </svg>
    </span>
  </button>

  <div
    class="accordion-content"
    role="region"
    id={panelId}
    aria-labelledby={buttonId}
  >
    <div class="accordion-body">
      {hasSlotContent ? <slot /> : content}
    </div>
  </div>
</div>

<style>
  .accordion-item {
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    transition:
      border-color var(--duration-std) var(--ease-standard),
      box-shadow var(--duration-slow) var(--ease-standard),
      transform var(--duration-slow) var(--ease-standard);
  }

  .accordion-item.open {
    border-color: var(--color-primary);
    box-shadow: 0 14px 32px rgba(5, 158, 216, 0.08);
    transform: translateY(-2px);
  }

  .accordion-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 0;
    font-family: inherit;
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    cursor: pointer;
    transition:
      background-color var(--duration-std) var(--ease-standard),
      color var(--duration-std) var(--ease-standard),
      transform var(--duration-bounce) var(--ease-bounce-soft);
  }

  .accordion-trigger:hover {
    background: var(--color-primary-subtle);
  }

  .accordion-item.open .accordion-trigger {
    background: var(--color-primary-subtle);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .accordion-trigger:focus-visible {
    outline: 0;
    box-shadow: var(--focus-ring);
  }

  .accordion-title {
    text-align: left;
  }

  .accordion-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform var(--duration-bounce) var(--ease-bounce-soft);
  }

  .accordion-icon svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition:
      opacity var(--duration-std) var(--ease-standard),
      transform var(--duration-bounce) var(--ease-bounce-soft);
  }

  .icon-minus {
    opacity: 0;
    transform: scale(0.7) rotate(-90deg);
  }

  .accordion-item.open .icon-plus {
    opacity: 0;
    transform: scale(0.7) rotate(90deg);
  }

  .accordion-item.open .icon-minus {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .accordion-content {
    display: grid;
    grid-template-rows: 0fr;
    background-color: var(--color-surface);
    overflow: hidden;
    transition:
      grid-template-rows var(--duration-bounce) var(--ease-bounce-soft),
      opacity var(--duration-fast) linear;
    opacity: 0;
  }

  .accordion-item.open .accordion-content {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .accordion-body {
    overflow: hidden;
    min-height: 0;
    padding: 0 var(--space-4);
    color: var(--color-text-secondary);
    line-height: var(--line-normal);
    transform: translateY(-0.4rem) scale(0.985);
    transform-origin: top center;
    transition:
      transform var(--duration-bounce) var(--ease-bounce-soft),
      opacity var(--duration-fast) linear;
    opacity: 0;
  }

  .accordion-item.open .accordion-body {
    margin-top: var(--space-3);
    padding-bottom: var(--space-4);
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .accordion-trigger,
    .accordion-content,
    .accordion-icon,
    .accordion-icon svg,
    .accordion-item,
    .accordion-body {
      transition: none;
    }
  }
</style>
