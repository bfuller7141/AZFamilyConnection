---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubpageHero from '../components/SubpageHero.astro';

import '../styles/base.css';
import '../styles/theme.root.css';
---

<BaseLayout
  title="Visitation Report | AZ Family Connections"
  description="Submit visitation report details to Arizona Family Connections, including timing, participants, visit summary, and pick-up information."
  language="en"
  canonical="/reports/"
>
  <SubpageHero
    subtitle="Visitation Reporting"
    title="Visitation Report Form"
    ctaText="Complete Report"
    ctaUrl="/reports/#reports-form"
    decorationLeft="/images/calendar-watermark.svg"
    decorationRight="/images/checkbox-watermark.svg"
  />

  <section class="report-section">
    <div class="report-container">
      <form
        class="report-form"
        method="POST"
        name="afc-reports"
        data-netlify="true"
        netlify-honeypot="bot-field"
        id="reports-form"
      >
        <input type="hidden" name="form-name" value="afc-reports" />
        <input type="hidden" name="custom-subject" value="" />
        <input type="hidden" name="subject" value="" />

        <p class="honeypot-field" aria-hidden="true">
          <label for="bot-field">Do not fill this field if you are human</label>
          <input id="bot-field" name="bot-field" type="text" />
        </p>

        <fieldset class="form-fieldset">
          <legend class="form-legend">Report Details</legend>

          <div class="form-row">
            <div class="form-group">
              <label for="reportDate" class="form-label">Date:</label>
              <input type="date" id="reportDate" name="reportDate" class="form-input" readonly required />
            </div>
          </div> 

          <div class="form-row">
            <div class="form-group">
              <label for="visitStartTime" class="form-label">Visitation Start Time:</label>
              <input type="time" id="visitStartTime" name="visitStartTime" class="form-input" />
            </div>
            <div class="form-group">
              <label for="visitEndTime" class="form-label">Visitation End Time:</label>
              <input type="time" id="visitEndTime" name="visitEndTime" class="form-input" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="familySupportSpecialist" class="form-label">Family Support Specialist:</label>
              <input
                type="text"
                id="familySupportSpecialist"
                name="familySupportSpecialist"
                class="form-input"
              />
            </div>
            <div class="form-group">
              <label for="visitingParentGuardian" class="form-label">Visiting Parent/Guardian:</label>
              <input type="text" id="visitingParentGuardian" name="visitingParentGuardian" class="form-input" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="custodialParentGuardian" class="form-label">Custodial Parent/Guardian:</label>
              <input type="text" id="custodialParentGuardian" name="custodialParentGuardian" class="form-input" />
            </div>
            <div class="form-group">
              <label for="children" class="form-label">Child (ren):</label>
              <input type="text" id="children" name="children" class="form-input" />
            </div>
          </div>

          <div class="form-group">
            <label for="location" class="form-label">Location:</label>
            <input type="text" id="location" name="location" class="form-input" />
          </div>

          <div class="form-group">
            <label for="visitationSummary" class="form-label">Visitation Summary:</label>
            <textarea id="visitationSummary" name="visitationSummary" class="form-textarea"></textarea>
          </div>

          <div class="form-group">
            <label for="pickUpInformation" class="form-label">Pick Up Information:</label>
            <textarea id="pickUpInformation" name="pickUpInformation" class="form-textarea"></textarea>
          </div>

          <div class="form-group">
            <label for="preparedBy" class="form-label">Prepared By:</label>
            <input type="text" id="preparedBy" name="preparedBy" class="form-input" />
          </div>
        </fieldset>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Submit Report</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .report-section {
    padding: 0 0 var(--space-8) 0;
  }

  .report-container {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 0 var(--pad-component-lg);
  }

  .report-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form-fieldset {
    border: 2px solid var(--brand-primary-200);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin: 0;
  }

  .form-legend {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--brand-primary-500);
    padding: 0 var(--space-2);
    margin-bottom: var(--space-4);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-4);
  }

  .form-label {
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .form-input,
  .form-select,
  .form-textarea {
    padding: var(--space-3);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-surface);
    transition: all var(--duration-std) var(--ease-standard);
  }

  .form-input:hover,
  .form-select:hover,
  .form-textarea:hover {
    border-color: var(--brand-primary-500);
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    border-color: var(--brand-primary-500);
  }

  .form-textarea {
    resize: vertical;
    min-height: 110px;
  }

  .submit-success {
    background: var(--color-success) !important;
    border-color: var(--color-success) !important;
    color: var(--color-success-contrast, #fff) !important;
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .honeypot-field {
    display: none;
  }

  @media (max-width: 767px) {
    .report-container {
      padding: 0 var(--pad-component);
    }

    .form-fieldset {
      padding: var(--space-4);
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .form-input,
    .form-select,
    .form-textarea {
      font-size: 16px;
    }
  }
</style>

<script is:inline type="module">
  function encodeFormData(data) {
    const pairs = [];
    for (const [key, value] of data.entries()) {
      pairs.push(encodeURIComponent(key) + '=' + encodeURIComponent(value));
    }
    return pairs.join('&');
  }

  function getLocalISODate() {
    const now = new Date();
    const year = now.getFullYear();
    const month = String(now.getMonth() + 1).padStart(2, '0');
    const day = String(now.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }

  const reportForm = document.querySelector('.report-form');
  const reportDateInput = document.getElementById('reportDate');
  const submitButton = reportForm instanceof HTMLFormElement
    ? reportForm.querySelector('button[type="submit"]')
    : null;
  const defaultSubmitText = submitButton instanceof HTMLButtonElement
    ? submitButton.textContent || 'Submit Report'
    : 'Submit Report';

  if (reportDateInput instanceof HTMLInputElement) {
    reportDateInput.value = getLocalISODate();
  }

  if (reportForm instanceof HTMLFormElement) {
    reportForm.addEventListener('submit', (event) => {
      event.preventDefault();

      const formData = new FormData(reportForm);
      const preparedBy = formData.get('preparedBy') || 'Team Member';

      formData.set('form-name', reportForm.getAttribute('name') || 'afc-reports');
      formData.set('custom-subject', `New Visitation Report from ${preparedBy}`);
      formData.set('subject', `New Visitation Report from ${preparedBy}`);

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.classList.remove('submit-success');
        submitButton.classList.add('btn-primary');
        submitButton.disabled = true;
        submitButton.textContent = 'Submitting...';
      }

      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: encodeFormData(formData),
      })
        .then(() => {
          setTimeout(() => {
            if (submitButton instanceof HTMLButtonElement) {
              submitButton.classList.remove('btn-primary');
              submitButton.classList.add('submit-success');
              submitButton.textContent = 'Report submitted successfully';
              submitButton.disabled = false;
            }
          }, 500);

          reportForm.reset();
          if (reportDateInput instanceof HTMLInputElement) {
            reportDateInput.value = getLocalISODate();
          }
        })
        .catch((error) => {
          console.error('Report form submission error:', error);
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.classList.remove('submit-success');
            submitButton.classList.add('btn-primary');
            submitButton.textContent = defaultSubmitText;
            submitButton.disabled = false;
          }
          alert('There was a problem submitting the form. Please try again.');
        });
    });
  }
</script>
